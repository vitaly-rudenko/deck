{
  "name": "@vitalyrudenko/deck",
  "version": "1.4.4",
  "description": "A deck for your widgets",
  "main": "dist/index.js",
  "bin": {
    "deck": "bin/deck"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "start": "tsx --env-file=.env src/app.tsx",
    "dev": "tsx --watch --env-file=.env src/app.tsx",
    "build": "esbuild src/app.tsx --bundle --platform=node --format=esm --jsx=automatic --packages=external --outfile=dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "type": "module",
  "dependencies": {
    "chalk": "^5.6.2",
    "ink": "^7.0.3",
    "ink-scroll-list": "^0.4.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.6",
    "strip-ansi": "^7.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "esbuild": "^0.25.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
